---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import ContactUs from '~/components/widgets/Contact.astro';

const metadata = {
  title: 'Hakkımızda – ComCoore Groups',
};
---

<Layout metadata={metadata}>
  <!-- Hero -->
  <Hero
    tagline="ComCoore Groups"
    image={{
      src: 'https://images.unsplash.com/photo-1559136555-9303baea8ebd?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'ComCoore Groups Kapak Görseli',
    }}
  >
    <Fragment slot="title">
      Dijital Dünyada Gücünüz: <span class="text-accent dark:text-white">ComCoore Groups</span> 💡
    </Fragment>
    <Fragment slot="subtitle">
      Güvenli, hızlı ve ölçeklenebilir çözümler sunan teknoloji girişimiyiz. Hedefimiz, bireylerin ve işletmelerin dijital dönüşümünde stratejik bir partner olmaktır.
    </Fragment>
  </Hero>

  <!-- Hizmet Alanlarımız -->
  <Features2
    title="Uzmanlık Alanlarımız"
    subtitle="İşinizi dijitalde büyütmek için ihtiyaç duyduğunuz tüm çözümler tek çatı altında."
    items={[
      {
        title: 'SMS ve Mobil Doğrulama',
        description: 'Güvenli ve hızlı kimlik doğrulama altyapıları.',
        icon: 'tabler:message-2-check',
      },
      {
        title: 'Dijital Reklam Optimizasyonu',
        description: 'Veriye dayalı planlama ve maksimum performans hedefli kampanyalar.',
        icon: 'tabler:chart-bar',
      },
      {
        title: 'Sosyal Medya Büyüme Çözümleri',
        description: 'Takipçi, beğeni, görüntülenme gibi sosyal etkileşim destekleri.',
        icon: 'tabler:users',
      },
      {
        title: 'Stratejik Danışmanlık',
        description: 'İş hedeflerinize özel analiz ve dijital yol haritası sunarız.',
        icon: 'tabler:compass',
      },
    ]}
  />

  <!-- Değerlerimiz -->
  <Steps2
    title="İşimizi Yapan Değerlerimiz"
    subtitle="ComCoore Groups olarak her projeye şu ilkelerle yaklaşırız:"
    items={[
      {
        title: 'Güvenilirlik',
        description: 'Taahhüt ettiğimiz kaliteyi zamanında sunarız.',
      },
      {
        title: 'Şeffaflık',
        description: 'İş süreçlerimizde açık iletişim ve dürüst raporlama esasımızdır.',
      },
      {
        title: 'Performans Odaklılık',
        description: 'Sonuç odaklıyız. Yatırımınızın karşılığını almanız önceliğimizdir.',
      },
    ]}
  />

  <!-- En Yeni Bloglar -->
  <BlogLatestPosts
    title="En Yeni İçerikler"
    information="Teknoloji, dijital pazarlama, girişimcilik ve strateji üzerine hazırladığımız güncel yazılarımıza göz atın."
  />

  <!-- İletişim -->
  <ContactUs
    id="form"
    title="ComCoore Groups ile İletişime Geçin"
    subtitle="İş birliği, teklif veya danışmanlık için bizimle iletişime geçin."
    inputs={[
      { type: 'text', name: 'name', label: 'Adınız' },
      { type: 'email', name: 'email', label: 'E-posta' },
    ]}
    textarea={{ label: 'Mesajınız' }}
    disclaimer={{
      label:
        'Formu göndererek kişisel bilgilerinizin gizlilik politikamız çerçevesinde işlenmesini kabul etmiş olursunuz.',
    }}
    description="Size en kısa sürede dönüş yapmamız için bilgilerinizi eksiksiz doldurun."
  />
  <!-- Alt Bilgi Mesajı -->
<footer class="mt-8 text-center text-sm text-muted">
<p>Ahmet Baş
</p>
  Bir gece ansızın gelir krallığınızı imparatorluğuma katarım.
</footer>
</Layout>
